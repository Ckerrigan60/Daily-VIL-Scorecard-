# ─── VIL Scorecard — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and should never be committed.

# ─── Google Sheets Integration ───────────────────────────────────────────────
# Step-by-step setup:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project (or use an existing one)
# 3. Enable the "Google Sheets API" for that project
# 4. Go to "IAM & Admin" > "Service Accounts" and create a service account
# 5. Grant it the "Editor" role (or at minimum Sheets Editor)
# 6. Click the service account > "Keys" > "Add Key" > "Create new key" > JSON
# 7. Download the JSON file and place it at credentials/google-service-account.json
# 8. Create a new Google Sheet at https://sheets.google.com
# 9. Share that sheet with the service account email (found in the JSON file under "client_email")
# 10. Copy the Sheet ID from the URL:
#     https://docs.google.com/spreadsheets/d/<<SHEET_ID_HERE>>/edit

GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_CREDENTIALS_PATH=credentials/google-service-account.json

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
